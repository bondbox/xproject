name = "xproject"
home = "https://github.com/bondbox/xproject/"
description = "Initialize project files"
keywords = [
    "project",
]
version = "0.3"

[authors.zoumingzhe]
name = "Mingzhe Zou"
email = "zoumingzhe@outlook.com"

[packages.xproject-python]
base = "xproject-python"
requires_python = ">=3.8"
authors = [
    "zoumingzhe",
]
keywords = []
requirements = [
    "xkits-command>=0.7",
    "xkits-config-toml>=0.8",
    "xkits-file>=0.10",
]
max_complexity = 15
max_line_length = 127

[packages.xproject-python.modules.xproject-python]
base = "xproject_python"
exclude = [
    "unittest",
]
omitted = [
    "attribute.py",
    "unittest/*",
]

[packages.xproject-python.modules.xproject-python.include]
templates = "templates"

[packages.xproject-python.modules.xproject-python.scripts]
xproject-python-config = "configure:main"
xproject-python-generate = "projector:main"

[packages.xproject-python.modules.xproject-python.templates]
"__init__.py" = false
"attribute.py" = true
